{
    "name": "dskripchenko/php-pdf",
    "description": "Pure-PHP PDF generator (HTML → PDF). Work in progress, research stage.",
    "type": "library",
    "license": "MIT",
    "keywords": ["pdf", "html-to-pdf", "pdf-writer"],
    "authors": [
        {
            "name": "Denis Skripchenko",
            "email": "denskrp90@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "ext-zlib": "*",
        "ext-dom": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\PhpPdf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dskripchenko\\PhpPdf\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
